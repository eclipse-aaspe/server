{
  "Query": {
    "$select": "match",
    "$condition":
     { "$or": [
       { "$and": [
         { "$match": [
           { "$eq": [
              { "$field": "$sme.Records[].ItemOfChange.TechnicalData_Changes[].ReasonId#value" },
              { "$strVal": "SOFTW" }
           ] },
           { "$eq": [
             { "$field": "$sme.Records[].ItemOfChange.TechnicalData_Changes[].Version#value" },
             { "$strVal": "1.4.0.3" }
           ] },
           { "$ge": [
             { "$field": "$sme.Records[].DateOfRecord#value" },
             { "$strVal": "2024-04-24T07:53Z" }
           ] }
         ] }
       ] }
     ] }
  }
}

