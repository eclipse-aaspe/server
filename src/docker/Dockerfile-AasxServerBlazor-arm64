# Use a multi-stage build to build and publish the .NET application
# Ubuntu 24.04 noble arm64 (Jammy: 9.0-jammy-arm64v8).
FROM mcr.microsoft.com/dotnet/sdk:9.0-noble-arm64v8 AS build-env
WORKDIR /repo/src

# Copy everything else and build
COPY ./src/ /repo/src/
COPY ./LICENSE.TXT /repo/LICENSE.txt

ARG AASX_SQLITE_BUNDLE=System
RUN dotnet clean
RUN dotnet restore -p:AasxSqliteNativeBundle=${AASX_SQLITE_BUNDLE}
RUN dotnet build -o /out/AasxServerBlazor AasxServerBlazor -v diag -p:AasxSqliteNativeBundle=${AASX_SQLITE_BUNDLE}
RUN dotnet publish -c Release -v diag --no-restore -p:AasxSqliteNativeBundle=${AASX_SQLITE_BUNDLE}

# Use a runtime image to run the application
# Specify the initial base architecture (amd64 in this case)
FROM mcr.microsoft.com/dotnet/aspnet:9.0-noble-arm64v8 as base
RUN apt-get update && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends curl nano libgdiplus libsqlite3-0 \
    && SO0="$(ls /usr/lib/*/libsqlite3.so.0 2>/dev/null | head -1)" \
    && test -n "$SO0" && ln -sf "$SO0" "$(dirname "$SO0")/libsqlite3.so" \
    && rm -rf /var/lib/apt/lists/*
EXPOSE 5001
COPY --from=build-env /out/AasxServerBlazor/ /AasxServerBlazor/
COPY ./content-for-demo/ /AasxServerBlazor/
WORKDIR /AasxServerBlazor
ENTRYPOINT ["/bin/bash", "-c", "./startForDemo.sh"]