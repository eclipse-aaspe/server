# Use a multi-stage build to build and publish the .NET application
# Specify the initial base architecture (amd64 in this case)
#
# Ubuntu 24.04 (noble): libsqlite3 from same distro line as typical LTS servers (Jammy: use 8.0-jammy tags instead).
FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/sdk:8.0-noble AS build-env
WORKDIR /repo/src

# Copy everything else and build
COPY ./src/ /repo/src/
COPY ./LICENSE.TXT /repo/LICENSE.txt

# System = SQLitePCLRaw loads distro libsqlite3 (installed below on Ubuntu). Embedded = bundled e_sqlite3 from NuGet.
ARG AASX_SQLITE_BUNDLE=System
RUN dotnet clean
RUN dotnet restore -p:AasxSqliteNativeBundle=${AASX_SQLITE_BUNDLE}
RUN dotnet build -o /out/AasxServerBlazor AasxServerBlazor -v d -p:AasxSqliteNativeBundle=${AASX_SQLITE_BUNDLE}
RUN dotnet publish -c Release -v d --no-restore -p:AasxSqliteNativeBundle=${AASX_SQLITE_BUNDLE}

# Use a runtime image to run the application
# Specify the initial base architecture (amd64 in this case)
FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/aspnet:8.0-noble as base
WORKDIR /repo/src
RUN apt-get update && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends curl nano libgdiplus libsqlite3-0 \
    && SO0="$(ls /usr/lib/*/libsqlite3.so.0 2>/dev/null | head -1)" \
    && test -n "$SO0" && ln -sf "$SO0" "$(dirname "$SO0")/libsqlite3.so" \
    && rm -rf /var/lib/apt/lists/*
ENV ASPNETCORE_URLS=http://+:5001
ENV ASPNETCORE_HTTP_PORTS=5001
EXPOSE 5001/tcp
EXPOSE 5001/udp
COPY --from=build-env /out/AasxServerBlazor/ /AasxServerBlazor/
COPY ./content-for-demo/ /AasxServerBlazor/
COPY ./src/AasxServerBlazor/appsettings.json /AasxServerBlazor/appsettings.json

WORKDIR /AasxServerBlazor
ENTRYPOINT ["/bin/bash", "-c", "./startForDemo.sh"]
