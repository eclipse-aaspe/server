# Use a multi-stage build to build and publish the .NET application
# Ubuntu 24.04 (noble); for 22.04 hosts use 9.0-jammy sdk/runtime tags.
FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/sdk:9.0-noble AS build-env
WORKDIR /repo/src

# Copy the source code and build
COPY ./src/ /repo/src/
COPY ./LICENSE.TXT /repo/LICENSE.txt

ARG AASX_SQLITE_BUNDLE=System
RUN dotnet clean
RUN dotnet restore -p:AasxSqliteNativeBundle=${AASX_SQLITE_BUNDLE}
RUN dotnet build -o /out/AasxServerAspNetCore AasxServerAspNetCore -v d -p:AasxSqliteNativeBundle=${AASX_SQLITE_BUNDLE}
RUN dotnet publish -c Release -v d --no-restore -p:AasxSqliteNativeBundle=${AASX_SQLITE_BUNDLE}

# Use a runtime image to run the application
FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/aspnet:9.0-noble as base
# Required for System bundle (libsqlite3.so + symlink for SQLitePCLRaw).
RUN apt-get update \
    && apt-get install -y --no-install-recommends libsqlite3-0 \
    && SO0="$(ls /usr/lib/*/libsqlite3.so.0 2>/dev/null | head -1)" \
    && test -n "$SO0" && ln -sf "$SO0" "$(dirname "$SO0")/libsqlite3.so" \
    && rm -rf /var/lib/apt/lists/*
EXPOSE 5001/tcp
EXPOSE 5001/udp
ENV ASPNETCORE_URLS=http://+:5001
COPY --from=build-env /out/AasxServerAspNetCore/ /AasxServerAspNetCore/
COPY ./content-for-demo/ /AasxServerAspNetCore/
WORKDIR /AasxServerAspNetCore
RUN chmod +x ./startForDemo.sh
ENTRYPOINT ["/bin/bash", "-c", "./startForDemo.sh"]
